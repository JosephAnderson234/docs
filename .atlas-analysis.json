  "keyFeatures": [
    "JWT authentication with httpOnly refresh token cookies",
    "Lead pipeline management with status tracking (EN_PROSPECTO → OFERTADO → CIERRE)",
    "Commercial activity tracking with Outlook Calendar & Microsoft Teams sync",
    "Quotation lifecycle management with atomic lead closing on accept/reject",
    "Organization management with SUNAT (Peru tax authority) lookup",
    "Contact management with multiple email addresses and organization association",
    "Role-based access control (ADMINISTRADOR / TRABAJADOR)",
    "Team invitation system with token-based onboarding",
    "Password reset via one-time email token",
    "Soft delete across all major entities",
    "Pagination and filtering on all list endpoints"
  ],
